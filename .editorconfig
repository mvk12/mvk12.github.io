root = true

[*.yml]
indent_style = space
indent_size = 2
tab_width = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2
tab_width = 2

[*.{js,mjs,ts,mts,vue}]
indent_style = space
indent_size = 2
tab_width = 2
trim_trailing_whitespace = true
